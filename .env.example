# BitGet API credentials
# Get these from: BitGet account → API Management
# Withdrawals: OFF. IP whitelist: ON.
BITGET_API_KEY=your_api_key_here
BITGET_SECRET_KEY=your_secret_key_here
BITGET_PASSPHRASE=your_passphrase_here
BITGET_BASE_URL=https://api.bitget.com

# Trading mode: "spot" or "futures"
TRADE_MODE=spot

# Portfolio value — used to display account value
PORTFOLIO_VALUE_USD=1000

# ── v8 Bot settings ────────────────────────────────────────────────────────────
# Risk per trade at FULL conviction (with-trend in bull/bear regime)
# Neutral regime uses 0.75×, against-trend uses 0.5×
# Position size = BASE_RISK_USD ÷ 7% SL  (e.g. $10 risk → $142 position)
# Rule of thumb: set to ~1% of your portfolio
BASE_RISK_USD=10

# Max simultaneous open positions across all 50 pairs
MAX_POSITIONS=30

# Set to "true" for paper trading (safe default — no real orders placed)
# Set to "false" only when you're ready to trade live
PAPER_TRADING=true

# ── Legacy single-symbol bot settings (bot.js) ────────────────────────────────
MAX_TRADE_SIZE_USD=100
MAX_TRADES_PER_DAY=3
SYMBOL=BTCUSDT
TIMEFRAME=4H
